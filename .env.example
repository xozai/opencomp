# ============================================================
# OpenComp — Example Environment Configuration
# Copy this file to .env and fill in values for local dev.
# Never commit .env to version control.
# ============================================================

# --- Database ---
DATABASE_URL=postgresql://opencomp:opencomp@localhost:5432/opencomp_dev
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- API Server ---
API_PORT=3000
API_HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=debug

# --- Auth ---
JWT_SECRET=change-me-in-production-use-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=another-long-random-string-for-refresh-tokens
JWT_REFRESH_EXPIRES_IN=7d

# --- Tenancy ---
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001

# --- Worker ---
WORKER_CONCURRENCY=5
WORKER_QUEUE_PREFIX=opencomp

# --- File Storage (local for dev) ---
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./tmp/uploads
STORAGE_MAX_FILE_SIZE_MB=25

# --- Email (console driver for dev — logs to stdout) ---
EMAIL_DRIVER=console
EMAIL_FROM=noreply@opencomp.dev
# EMAIL_DRIVER=smtp
# EMAIL_SMTP_HOST=localhost
# EMAIL_SMTP_PORT=1025

# --- Feature Flags ---
ENABLE_AUDIT_LOG=true
ENABLE_EVENT_BUS=true
ENABLE_NOTIFICATIONS=true

# --- Observability ---
OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
