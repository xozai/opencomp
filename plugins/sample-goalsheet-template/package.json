{
  "name": "@opencomp/sample-goalsheet-template",
  "version": "0.1.0",
  "description": "Sample goal sheet template plugin — demonstrates how to customise goal sheet content and rendering",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts",
    "dev": "tsup src/index.ts --format cjs --dts --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opencomp/contracts": "workspace:*",
    "@opencomp/sdk": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.2",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
