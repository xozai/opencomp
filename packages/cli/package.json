{
  "name": "@opencomp/cli",
  "version": "0.1.0",
  "description": "OpenComp CLI — scaffold plugins, generate types, run admin commands",
  "bin": {
    "opencomp": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/cli.ts src/index.ts --format cjs --dts",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@opencomp/contracts": "workspace:*",
    "commander": "^12.0.0",
    "ora": "^8.0.1",
    "chalk": "^5.3.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/prompts": "^2.4.9",
    "tsup": "^8.0.2",
    "tsx": "^4.7.3",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
