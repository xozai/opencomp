{
  "name": "@opencomp/worker",
  "version": "0.1.0",
  "private": true,
  "description": "OpenComp async job worker (BullMQ)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
