    "ioredis": "^5.3.2",
    "pg": "^8.11.5",
    "pino": "^9.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/pg": "^8.11.5",
    "tsx": "^4.7.3",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
