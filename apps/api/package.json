{
  "name": "@opencomp/api",
  "version": "0.1.0",
  "private": true,
  "description": "OpenComp REST API server (Fastify)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^4.0.1",
    "@opencomp/contracts": "workspace:*",
    "@opencomp/events": "workspace:*",
    "@opencomp/nl-rules": "workspace:*",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.30.0",
    "fastify": "^4.27.0",
    "pg": "^8.11.5",
    "pino": "^9.1.0",
    "pino-pretty": "^13.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/pg": "^8.11.5",
    "drizzle-kit": "^0.21.0",
    "supertest": "^7.0.0",
    "tsx": "^4.7.3",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
